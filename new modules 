const { z } = require('zod'); // Add to package.json: "zod": "^3.22.4"

class EvidenceVerifier {
  constructor() {
    // Validation schemas for each specialist output
    this.SCHEMAS = {
      diagnostic: z.object({
        rootCauses: z.array(z.object({
