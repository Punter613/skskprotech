openapi: 3.0.3
info:
  title: SKSK ProTech API
  version: "1.0.0"
  description: Mobile diagnostic, estimation, and invoicing API for SKSK ProTech.
servers:
  - url: https://api.skskprotech.local
    description: Local dev server
tags:
  - name: invoice
    description: Invoice generation and PDF export
  - name: diagnose
    description: Local diagnostics and repair guidance
  - name: estimate
    description: Heuristic estimate engine (protected)

components:
  securitySchemes:
    BearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
  schemas:
    ErrorResponse:
      type: object
      properties:
        success:
          type: boolean
          example: false
        error:
          type: string
        details:
          type: string
        trace:
          type: string
          description: Correlation id for logs
    Customer:
      type: object
      properties:
        name:
          type: string
        phone:
          type: string
    Part:
      type: object
      properties:
        name:
          type: string
        cost:
          type: number
          format: float
    InvoiceRequest:
      type: object
      required: [customer, vehicle]
      properties:
        customer:
          $ref: '#/components/schemas/Customer'
        vehicle:
          type: object
          properties:
            year:
              type: integer
            make:
              type: string
            model:
              type: string
            trim:
              type: string
        mileage:
          type: integer
        obdCodes:
          type: array
          items:
            type: string
        symptoms:
          type: array
          items:
            type: string
        laborRate:
          type: number
          format: float
        estimatedHours:
          type: number
          format: float
        partsCost:
          type: number
          format: float
        parts:
          type: array
          items:
            $ref: '#/components/schemas/Part'
    InvoiceResponse:
      type: object
      properties:
        success:
          type: boolean
          example: true
        invoiceId:
          type: string
        pdfUrl:
          type: string
    DiagnoseRequest:
      type: object
      properties:
        vehicle:
          type: object
          properties:
            year:
              type: integer
            make:
              type: string
            trim:
              type: string
        obdCodes:
          type: array
          items:
            type: string
        customerStates:
          type: array
          items:
            type: string
    DiagnoseResult:
      type: object
      properties:
        success:
          type: boolean
          example: true
        result:
          type: object
          properties:
            localVehicleTelemetry:
              type: object
              properties:
                vehicleId:
                  type: string
            primaryCause:
              type: string
            notes:
              type: string
            repairSteps:
              type: array
              items:
                type: string
    EstimateRequest:
      type: object
      properties:
        vehicle:
          type: object
        obdCodes:
          type: array
          items:
            type: string
        jobContext:
          type: object
    EstimateResponse:
      type: object
      properties:
        success:
          type: boolean
        estimateId:
          type: string
        total:
          type: number
          format: float
        breakdown:
          type: object

paths:
  /api/invoice:
    post:
      tags:
        - invoice
      summary: Generate invoice PDF
      operationId: createInvoice
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/InvoiceRequest'
            example:
              customer:
                name: "Johnny Castaway"
                phone: "330-555-0199"
              vehicle:
                year: 2012
                make: "Ram"
                model: "1500"
                trim: "Laramie 5.7L"
              mileage: 142500
              obdCodes: ["P0303"]
              symptoms: ["Lifter Tick", "Misfire under load"]
              laborRate: 85
              estimatedHours: 12.0
              partsCost: 485.50
              parts:
                - name: "Mopar Camshaft (53022263AF)"
                  cost: 225.00
                - name: "Mopar MDS Lifter Yoke Set"
                  cost: 260.50
      responses:
        '200':
          description: PDF invoice binary
          content:
            application/pdf:
              schema:
                type: string
                format: binary
        '400':
          description: Bad request
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      x-offline-capable: true

  /api/diagnose:
    post:
      tags:
        - diagnose
      summary: Run local diagnostics and return repair guidance
      operationId: runDiagnose
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DiagnoseRequest'
            example:
              vehicle:
                year: 2012
                make: "Ram"
                trim: "hemi"
              obdCodes: ["P0303"]
              customerStates: ["lifter tick", "misfire"]
      responses:
        '200':
          description: Diagnostic result
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DiagnoseResult'
        '400':
          description: Bad request
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '503':
          description: External dependency not configured
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'

  /api/estimateHeuristic:
    post:
      tags:
        - estimate
      summary: Heuristic estimate engine
      operationId: createEstimate
      security:
        - BearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/EstimateRequest'
            example:
              vehicle:
                year: 2012
                make: "Ram"
                trim: "hemi"
              obdCodes: ["P0303"]
              jobContext:
                urgency: "standard"
      responses:
        '200':
          description: Estimate result
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/EstimateResponse'
        '400':
          description: Bad request
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '403':
          description: Forbidden
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '503':
          description: Service unavailable
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'

security:
  - {}
