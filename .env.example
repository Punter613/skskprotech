PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.com
REQUEST_TIMEOUT_MS=30000

GROQ_API_KEY=your_groq_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Required in production — auth.js will refuse to boot without this
JWT_SECRET=your_jwt_secret_here

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# db.js also accepts SUPABASE_KEY or SUPABASE_ANON_KEY as fallbacks, in that order

EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here
EBAY_MARKETPLACE_ID=your_ebay_marketplace_id_here

AI_URL=
REDIS_URL=

DEFAULT_LABOR_RATE=65
TAX_RATE=0.07
SHOP_SUPPLIES_RATE=0.07

INTEL_ENABLED=true
CHARM_ENABLED=false
LIVE_SEARCH_ENABLED=false
STRIPE_ENABLED=false
